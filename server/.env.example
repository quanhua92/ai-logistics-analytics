# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://logistics:logistics@localhost:15443/logistics

# ── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=["http://localhost:3000"]

# ── AI provider (OpenAI-compatible) ────────────────────────
# Works with OpenAI, OpenRouter, Together, Groq, etc.
# Get an OpenRouter key at https://openrouter.ai/keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=poolside/laguna-s-2.1:free

# ── Chat access gate (Phase 1.5) ───────────────────────────
# Gate ONLY the /api/chat endpoint (the token-spending route).
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable the gate during development.
CHAT_ACCESS_KEY=

# ── Per-conversation chat logs (debug) ─────────────────────
# One JSONL file per conversation UUID is appended here. Gitignored.
CHAT_LOG_DIR=.chat-logs
